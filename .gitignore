cat > .gitignore << 'EOF'
# Compiled class files
*.class

# Package Files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Virtual machine crash logs
hs_err_pid*
replay_pid*

# IDE - VS Code
.vscode/
*.code-workspace

# IDE - IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/

# IDE - Eclipse
.classpath
.project
.settings/
bin/

# Build directories
build/
target/
dist/

# Database files
*.db
*.sqlite
*.log

# OS generated files
.DS_Store
Thumbs.db

# Java compilation output
bin/
out/
EOF